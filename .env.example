# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/smart-outreach

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production

# ─── Email Sending (SMTP) ─────────────────────────────────────────────────────
# Set ENABLE_REAL_EMAIL_SEND=true to actually send outbound campaign emails
ENABLE_REAL_EMAIL_SEND=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart Outreach <your-email@domain.com>"

# Optional: cap how many recipients are emailed per campaign send
CAMPAIGN_MAX_RECIPIENTS_PER_SEND=50

# ─── Gmail OAuth (for inbox sync) ─────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret
# Must match the redirect URI registered in Google Cloud Console
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ─── Email Tracking ───────────────────────────────────────────────────────────
# Base URL of this backend — used to generate click/open tracking links in emails
TRACKING_BASE_URL=http://localhost:4000/api/track
